<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:padding="16dp">

    <!-- 状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#16213E"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="未连接"
            android:textColor="#E94560"
            android:textSize="16sp"
            android:gravity="center_vertical" />

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="连接设备"
            android:backgroundTint="#0F3460"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- 当前发送码显示 -->
    <TextView
        android:id="@+id/tvOpcode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="发送：0x00"
        android:textColor="#888888"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <!-- 控制方向区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <!-- 行 1：左平移 | 前进 | 右平移 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnStrafeLeft"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:text="◀ 左平"
                android:backgroundTint="#0F3460"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:enabled="false"
                android:alpha="0.4"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnForward"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:text="▲ 前进"
                android:backgroundTint="#0F3460"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:enabled="false"
                android:alpha="0.4"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnStrafeRight"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:text="右平 ▶"
                android:backgroundTint="#0F3460"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:enabled="false"
                android:alpha="0.4" />
        </LinearLayout>

        <!-- 行 2：左转 | 停止 | 右转 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnTurnLeft"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:text="↰ 左转"
                android:backgroundTint="#0F3460"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:enabled="false"
                android:alpha="0.4"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:text="■ 停止"
                android:backgroundTint="#E94560"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:enabled="false"
                android:alpha="0.4"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnTurnRight"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:text="右转 ↱"
                android:backgroundTint="#0F3460"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:enabled="false"
                android:alpha="0.4" />
        </LinearLayout>

        <!-- 行 3：空 | 后退 | 空 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnBackward"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:text="▼ 后退"
                android:backgroundTint="#0F3460"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:enabled="false"
                android:alpha="0.4"
                android:layout_marginEnd="8dp" />

            <View
                android:layout_width="90dp"
                android:layout_height="90dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 速度滑块区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#16213E"
        android:padding="16dp"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="调速"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="速度：1 档"
                android:textColor="#E94560"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 档位标签 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="1档" android:textColor="#888888"
                android:textSize="12sp" android:gravity="center" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="2档" android:textColor="#888888"
                android:textSize="12sp" android:gravity="center" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="3档" android:textColor="#888888"
                android:textSize="12sp" android:gravity="center" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="4档" android:textColor="#888888"
                android:textSize="12sp" android:gravity="center" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekSpeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="3"
            android:progress="0"
            android:progressTint="#E94560"
            android:thumbTint="#E94560"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</LinearLayout>
